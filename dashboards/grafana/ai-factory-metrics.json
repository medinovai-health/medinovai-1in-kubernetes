{
  "dashboard": {
    "title": "AI Factory - Model Performance",
    "tags": ["ai", "ml", "models", "ollama"],
    "timezone": "browser",
    "schemaVersion": 36,
    "refresh": "30s",
    "time": { "from": "now-1h", "to": "now" },
    "panels": [
      {
        "id": 1,
        "title": "Active Models",
        "type": "stat",
        "targets": [{ "expr": "aifactory_active_models", "refId": "A" }],
        "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 }
      },
      {
        "id": 2,
        "title": "Inference Requests/sec",
        "type": "stat",
        "targets": [{ "expr": "rate(aifactory_inference_total[1m])", "refId": "A" }],
        "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 }
      },
      {
        "id": 3,
        "title": "Avg Inference Latency",
        "type": "stat",
        "targets": [{ "expr": "aifactory_inference_latency_seconds", "refId": "A" }],
        "fieldConfig": { "defaults": { "unit": "s" } },
        "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 }
      },
      {
        "id": 4,
        "title": "GPU Utilization",
        "type": "gauge",
        "targets": [{ "expr": "aifactory_gpu_utilization", "refId": "A" }],
        "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } },
        "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 }
      },
      {
        "id": 5,
        "title": "Model Request Distribution",
        "type": "piechart",
        "targets": [{ "expr": "aifactory_requests_by_model", "legendFormat": "{{model}}", "refId": "A" }],
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 }
      },
      {
        "id": 6,
        "title": "Token Generation Rate",
        "type": "timeseries",
        "targets": [{ "expr": "rate(aifactory_tokens_generated_total[5m])", "legendFormat": "tokens/sec", "refId": "A" }],
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 }
      },
      {
        "id": 7,
        "title": "Queue Depth by Model",
        "type": "timeseries",
        "targets": [{ "expr": "aifactory_queue_depth", "legendFormat": "{{model}}", "refId": "A" }],
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 }
      },
      {
        "id": 8,
        "title": "Model Load Time",
        "type": "timeseries",
        "targets": [{ "expr": "aifactory_model_load_seconds", "legendFormat": "{{model}}", "refId": "A" }],
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 }
      },
      {
        "id": 9,
        "title": "Ollama Node Status",
        "type": "table",
        "targets": [{ "expr": "aifactory_node_info", "format": "table", "refId": "A" }],
        "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 }
      }
    ]
  },
  "overwrite": true
}
