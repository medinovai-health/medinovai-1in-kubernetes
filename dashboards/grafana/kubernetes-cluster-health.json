{
  "dashboard": {
    "title": "Kubernetes Cluster Health",
    "tags": ["kubernetes", "k8s", "cluster", "docker-desktop"],
    "timezone": "browser",
    "schemaVersion": 36,
    "refresh": "15s",
    "time": { "from": "now-30m", "to": "now" },
    "panels": [
      {
        "id": 1,
        "title": "Node Status",
        "type": "stat",
        "targets": [{ "expr": "kube_node_status_condition{condition=\"Ready\"}", "legendFormat": "{{node}}", "refId": "A" }],
        "gridPos": { "h": 4, "w": 24, "x": 0, "y": 0 }
      },
      {
        "id": 2,
        "title": "Pod Count by Namespace",
        "type": "timeseries",
        "targets": [{ "expr": "count(kube_pod_info) by (namespace)", "legendFormat": "{{namespace}}", "refId": "A" }],
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 }
      },
      {
        "id": 3,
        "title": "Container Restarts",
        "type": "timeseries",
        "targets": [{ "expr": "rate(kube_pod_container_status_restarts_total[5m])", "legendFormat": "{{pod}} - {{container}}", "refId": "A" }],
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 }
      },
      {
        "id": 4,
        "title": "Cluster CPU Utilization",
        "type": "timeseries",
        "targets": [{ "expr": "sum(rate(container_cpu_usage_seconds_total{id=\"/\"}[5m]))", "refId": "A" }],
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 }
      },
      {
        "id": 5,
        "title": "Cluster Memory Utilization",
        "type": "timeseries",
        "targets": [{ "expr": "sum(container_memory_usage_bytes{id=\"/\"})", "refId": "A" }],
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 }
      },
      {
        "id": 6,
        "title": "Network I/O",
        "type": "timeseries",
        "targets": [
          { "expr": "rate(container_network_receive_bytes_total[5m])", "legendFormat": "RX", "refId": "A" },
          { "expr": "rate(container_network_transmit_bytes_total[5m])", "legendFormat": "TX", "refId": "B" }
        ],
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 }
      },
      {
        "id": 7,
        "title": "Disk I/O",
        "type": "timeseries",
        "targets": [
          { "expr": "rate(container_fs_reads_bytes_total[5m])", "legendFormat": "Read", "refId": "A" },
          { "expr": "rate(container_fs_writes_bytes_total[5m])", "legendFormat": "Write", "refId": "B" }
        ],
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 }
      },
      {
        "id": 8,
        "title": "PVC Usage",
        "type": "table",
        "targets": [{ "expr": "kubelet_volume_stats_used_bytes / kubelet_volume_stats_capacity_bytes", "format": "table", "refId": "A" }],
        "gridPos": { "h": 8, "w": 24, "x": 0, "y": 28 }
      }
    ]
  },
  "overwrite": true
}
