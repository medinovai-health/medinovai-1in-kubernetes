{
  "dashboard": {
    "title": "Healthcare Clinical Metrics",
    "tags": ["healthcare", "clinical", "phi"],
    "timezone": "browser",
    "schemaVersion": 36,
    "refresh": "1m",
    "time": { "from": "now-6h", "to": "now" },
    "panels": [
      {
        "id": 1,
        "title": "Active Clinical Trials",
        "type": "stat",
        "targets": [
          {
            "expr": "ctms_active_trials_total",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "fixed", "fixedColor": "blue" },
            "unit": "short"
          }
        },
        "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 }
      },
      {
        "id": 2,
        "title": "Enrolled Patients",
        "type": "stat",
        "targets": [
          {
            "expr": "ctms_enrolled_patients_total",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "fixed", "fixedColor": "green" }
          }
        },
        "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 }
      },
      {
        "id": 3,
        "title": "Lab Samples Processed",
        "type": "stat",
        "targets": [
          {
            "expr": "lis_samples_processed_total",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "fixed", "fixedColor": "purple" }
          }
        },
        "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 }
      },
      {
        "id": 4,
        "title": "SAE Reports",
        "type": "stat",
        "targets": [
          {
            "expr": "saes_reports_total",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "fixed", "fixedColor": "red" }
          }
        },
        "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 }
      },
      {
        "id": 5,
        "title": "Patient Enrollment Trend",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate(ctms_enrolled_patients_total[1h])",
            "legendFormat": "Enrollments/hour",
            "refId": "A"
          }
        ],
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 }
      },
      {
        "id": 6,
        "title": "Lab Turnaround Time (hours)",
        "type": "gauge",
        "targets": [
          {
            "expr": "lis_avg_turnaround_hours",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "min": 0,
            "max": 72,
            "thresholds": {
              "steps": [
                { "color": "green", "value": 0 },
                { "color": "yellow", "value": 24 },
                { "color": "red", "value": 48 }
              ]
            },
            "unit": "h"
          }
        },
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 }
      },
      {
        "id": 7,
        "title": "Consent Status Distribution",
        "type": "piechart",
        "targets": [
          {
            "expr": "econsent_status_total",
            "legendFormat": "{{status}}",
            "refId": "A"
          }
        ],
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 }
      },
      {
        "id": 8,
        "title": "ePRO Completion Rate",
        "type": "timeseries",
        "targets": [
          {
            "expr": "epro_completion_rate",
            "legendFormat": "Completion %",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "min": 0,
            "max": 1
          }
        },
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 }
      },
      {
        "id": 9,
        "title": "Study Site Performance",
        "type": "table",
        "targets": [
          {
            "expr": "ctms_site_enrollment_rate",
            "format": "table",
            "refId": "A"
          }
        ],
        "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 }
      }
    ]
  },
  "overwrite": true
}
