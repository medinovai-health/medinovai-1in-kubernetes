# Test automation for medinovai-1in-kubernetes
# (c) 2026 MedinovAI — Sprint 12

.PHONY: test test-unit test-integration test-e2e test-performance test-all

test-unit:
	@echo "Running unit tests for medinovai-1in-kubernetes..."
	pytest tests/unit -v --cov=src --cov-report=xml

test-integration:
	@echo "Running integration tests for medinovai-1in-kubernetes..."
	pytest tests/integration -v --cov=src

test-e2e:
	@echo "Running E2E tests for medinovai-1in-kubernetes..."
	pytest tests/e2e -v

test-performance:
	@echo "Running performance tests for medinovai-1in-kubernetes..."
	k6 run tests/performance/load.js

test-all: test-unit test-integration test-e2e
	@echo "All tests completed for medinovai-1in-kubernetes"

test: test-unit
