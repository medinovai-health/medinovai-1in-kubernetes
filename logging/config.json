{
  "logging": {
    "format": "json",
    "level": "info",
    "rotation": {
      "enabled": true,
      "maxSize": "100M",
      "maxFiles": 10,
      "compress": true
    },
    "correlationId": {
      "header": "X-Correlation-ID",
      "enabled": true
    },
    "hipaaAudit": {
      "enabled": true,
      "logSuccessful": true,
      "logFailed": true
    }
  }
}
