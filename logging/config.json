{
  "logging": {
    "level": "info",
    "format": "json",
    "rotation": {
      "enabled": true,
      "max_size": "10MB",
      "max_files": 5
    },
    "correlation_id": {
      "header": "X-Correlation-ID",
      "enabled": true
    },
    "hipaa_audit": {
      "enabled": true,
      "log_level": "audit",
      "fields": ["user_id", "patient_id", "event_type"]
    }
  }
}
