// MedinovAI Fleet Configuration — On-Prem K3s Cluster
// Defines all physical nodes in the deployment fleet.
{
  cluster_name: "medinovai-onprem",
  k3s_version: "v1.30",

  // K3s networking
  pod_cidr: "10.42.0.0/16",
  service_cidr: "10.43.0.0/16",

  nodes: [
    {
      hostname: "mac-studio",
      actual_hostname: "aifactory.local",
      role: "server",
      lan_ip: "192.168.68.54",          // WiFi; ethernet: 192.168.0.102
      tailscale_ip: "100.106.54.9",     // mayanks-mac-studio-1.tail3b5737.ts.net
      ssh_user: "mayanktrivedi",
      os: "darwin",
      arch: "arm64",
      gpu: false,
      vm_runtime: "orbstack",
      vm_name: "k3s-medinovai",
      labels: {
        "role": "control-plane",
        "gpu": "false",
        "medinovai.com/tier": "infra",
      },
      services: [
        "postgres-primary", "postgres-clinical", "redis-cache",
        "kafka", "mongodb", "elasticsearch", "keycloak", "vault",
        "atlas-gateway", "atlas-ui", "atlas-orchestrator",
        "event-bus", "rollup-engine", "audit-chain",
        "prometheus", "grafana", "loki", "alertmanager",
      ],
    },
    {
      hostname: "macbook-pro",
      actual_hostname: "Mayank-MBP25-7472.local",
      role: "agent",
      lan_ip: "dynamic",               // DHCP; current: 192.168.68.87
      tailscale_ip: "100.79.214.33",   // mayank-mbp25.tail3b5737.ts.net
      ssh_user: "mayanktrivedi",
      os: "darwin",
      arch: "arm64",
      gpu: false,
      vm_runtime: "orbstack",
      vm_name: "k3s-medinovai-worker",
      labels: {
        "role": "worker",
        "gpu": "false",
        "medinovai.com/tier": "compute",
      },
      services: [
        "medinovaios", "medinovai-api-gateway",
        // Overflow: domain services, integration services
      ],
    },
    {
      hostname: "dgx-1",
      actual_hostname: "spark-08dd",
      role: "agent",
      lan_ip: "192.168.68.78",          // WiFi (wlP9s9); ethernet: 192.168.0.100
      tailscale_ip: "100.125.48.57",    // spark-08dd.tail3b5737.ts.net
      os: "linux",
      arch: "amd64",
      gpu: true,
      gpu_model: "NVIDIA-GB10",         // DGX Spark GB10 Superchip
      gpu_count: 1,
      gpu_memory_mib: 131072,           // 128 GB unified memory
      ssh_user: "mayank",               // nvsync key: ~/Library/Application Support/NVIDIA/Sync/config/nvsync.key
      labels: {
        "role": "gpu-worker",
        "gpu": "true",
        "medinovai.com/tier": "gpu",
        "medinovai.com/dgx-node": "1",
      },
      services: [
        "ollama", "aifactory-node-1",
        "medinovai-ai-scribe", "medinovai-cds",
      ],
    },
    {
      hostname: "dgx-2",
      actual_hostname: "spark-d0a6",
      role: "agent",
      lan_ip: "192.168.68.60",          // WiFi (wlP9s9); ethernet: 192.168.0.101
      tailscale_ip: "100.94.48.43",     // spark-d0a6.tail3b5737.ts.net
      os: "linux",
      arch: "amd64",
      gpu: true,
      gpu_model: "NVIDIA-GB10",         // DGX Spark GB10 Superchip
      gpu_count: 1,
      gpu_memory_mib: 131072,           // 128 GB unified memory
      ssh_user: "mayank",
      labels: {
        "role": "gpu-worker",
        "gpu": "true",
        "medinovai.com/tier": "gpu",
        "medinovai.com/dgx-node": "2",
      },
      services: [
        "ollama", "aifactory-node-2",
        "medinovai-pathology-ai", "medinovai-genomics-interpreter",
      ],
    },
  ],
}
