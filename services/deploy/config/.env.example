# ─── MedinovAI Atlas Environment Variables ───────────────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit the .env file to version control.

# ─── Slack (Socket Mode) ─────────────────────────────────────────────────────
SLACK_APP_TOKEN=xapp-REPLACE_ME
SLACK_BOT_TOKEN=xoxb-REPLACE_ME

# ─── Model Provider Keys ─────────────────────────────────────────────────────
# At least one is required. Uncomment and fill in the ones you use.
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
# OPENAI_API_KEY=sk-REPLACE_ME
# GOOGLE_AI_API_KEY=REPLACE_ME

# ─── Hooks / Webhooks ────────────────────────────────────────────────────────
HOOKS_TOKEN=REPLACE_WITH_RANDOM_SECRET

# ─── CRM Integration ─────────────────────────────────────────────────────────
# CRM_API_KEY=REPLACE_ME
# CRM_API_URL=https://api.yourcrm.com/v1

# ─── Ticketing System ────────────────────────────────────────────────────────
# TICKETS_API_KEY=REPLACE_ME
# TICKETS_API_URL=https://api.yourtickets.com/v1

# ─── Gmail (for Pub/Sub watch) ───────────────────────────────────────────────
# GMAIL_SERVICE_ACCOUNT_JSON=path/to/service-account.json
# GMAIL_WATCH_EMAIL=inbox@yourcompany.com

# ─── Finance / Accounting ────────────────────────────────────────────────────
# ACCOUNTING_API_KEY=REPLACE_ME

# ─── Google Ads ────────────────────────────────────────────────────────────
# GOOGLE_ADS_DEVELOPER_TOKEN=REPLACE_ME
# GOOGLE_ADS_CLIENT_ID=REPLACE_ME
# GOOGLE_ADS_CLIENT_SECRET=REPLACE_ME
# GOOGLE_ADS_REFRESH_TOKEN=REPLACE_ME
# GOOGLE_ADS_CUSTOMER_ID=REPLACE_ME

# ─── LinkedIn Analytics ───────────────────────────────────────────────────
# LINKEDIN_CLIENT_ID=REPLACE_ME
# LINKEDIN_CLIENT_SECRET=REPLACE_ME
# LINKEDIN_ACCESS_TOKEN=REPLACE_ME
# LINKEDIN_ORGANIZATION_ID=REPLACE_ME

# ─── Google Analytics 4 ──────────────────────────────────────────────────
# GA4_PROPERTY_ID=REPLACE_ME
# GA4_SERVICE_ACCOUNT_JSON=path/to/ga4-service-account.json

# ─── PagerDuty ────────────────────────────────────────────────────────────
# PAGERDUTY_API_KEY=REPLACE_ME

# ─── Linear / Jira ───────────────────────────────────────────────────────
# LINEAR_API_KEY=REPLACE_ME
# JIRA_URL=https://your-org.atlassian.net
# JIRA_API_TOKEN=REPLACE_ME
# JIRA_USER_EMAIL=REPLACE_ME

# ─── Glassdoor / Indeed ──────────────────────────────────────────────────
# GLASSDOOR_PARTNER_ID=REPLACE_ME
# GLASSDOOR_API_KEY=REPLACE_ME

# ─── Crunchbase ──────────────────────────────────────────────────────────
# CRUNCHBASE_API_KEY=REPLACE_ME

# ─── Misc ────────────────────────────────────────────────────────────────
# NOTION_API_KEY=REPLACE_ME
