{
  "service": "patientmatching",
  "version": "0.1.0",
  "repo": "medinovai/medinovai-patientmatching",
  "type": "node-service",
  "tier": "high",
  "description": "Patient identity matching and deduplication service",
  "dependencies": {
    "services": ["security", "patient-services"],
    "databases": ["postgres-primary", "elasticsearch", "kafka"],
    "external": []
  },
  "health": {
    "endpoint": "/healthz",
    "readiness": "/ready",
    "startup_timeout_seconds": 30
  },
  "deploy": {
    "strategy": "canary",
    "canary_percentage": 10,
    "canary_duration_minutes": 10,
    "rollback_on_error_rate": 0.01
  },
  "resources": {
    "cpu": { "request": "250m", "limit": "1000m" },
    "memory": { "request": "256Mi", "limit": "1Gi" },
    "gpu": false
  },
  "scaling": {
    "min_replicas": 1,
    "max_replicas": 5,
    "target_cpu_percent": 70
  },
  "governance": {
    "risk_class": "high",
    "requires_approval": true,
    "pii_handling": true,
    "audit_logging": true
  }
}
