{
  "service": "data-lake-loader",
  "version": "0.1.0",
  "repo": "myonsite-healthcare/data-lake-loader",
  "type": "python-service",
  "tier": "normal",
  "description": "Data lake loader from stream bus and data services. Data lineage required.",
  "dependencies": {
    "services": ["stream-bus", "data-services"],
    "databases": [],
    "external": ["kafka", "s3"]
  },
  "health": {
    "endpoint": "/health",
    "readiness": "/ready",
    "startup_timeout_seconds": 30
  },
  "deploy": {
    "strategy": "rolling",
    "canary_percentage": 10,
    "canary_duration_minutes": 10,
    "rollback_on_error_rate": 0.01
  },
  "resources": {
    "cpu": { "request": "250m", "limit": "1000m" },
    "memory": { "request": "256Mi", "limit": "1Gi" },
    "gpu": false
  },
  "scaling": {
    "min_replicas": 1,
    "max_replicas": 5,
    "target_cpu_percent": 70
  },
  "governance": {
    "risk_class": "medium",
    "requires_approval": false,
    "pii_handling": false,
    "audit_logging": true,
    "data_lineage_required": true
  }
}
