{
  "service": "api-gateway",
  "version": "0.1.0",
  "repo": "myonsite-healthcare/medinovai-api-gateway",
  "type": "node-service",
  "tier": "critical",
  "description": "API gateway routing external traffic to backend services",
  "dependencies": {
    "services": ["auth-service", "clinical-engine", "data-pipeline", "ai-inference", "notification-service"],
    "databases": [],
    "external": []
  },
  "health": {
    "endpoint": "/health",
    "readiness": "/ready",
    "startup_timeout_seconds": 30
  },
  "deploy": {
    "strategy": "canary",
    "canary_percentage": 5,
    "canary_duration_minutes": 10,
    "rollback_on_error_rate": 0.01
  },
  "resources": {
    "cpu": { "request": "250m", "limit": "1000m" },
    "memory": { "request": "256Mi", "limit": "1Gi" },
    "gpu": false
  },
  "scaling": {
    "min_replicas": 2,
    "max_replicas": 20,
    "target_cpu_percent": 70
  },
  "governance": {
    "risk_class": "high",
    "requires_approval": true,
    "pii_handling": false,
    "audit_logging": true
  }
}
