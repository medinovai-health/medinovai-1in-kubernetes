{
  "service": "qa-agent-builder",
  "version": "0.1.0",
  "repo": "myonsite-healthcare/qa-agent-builder",
  "type": "python-service",
  "tier": "normal",
  "description": "QA agent builder with security and model orchestrator. Model risk register required.",
  "dependencies": {
    "services": ["security", "model-orchestrator"],
    "databases": ["postgres-primary"],
    "external": []
  },
  "health": {
    "endpoint": "/health",
    "readiness": "/ready",
    "startup_timeout_seconds": 30
  },
  "deploy": {
    "strategy": "rolling",
    "canary_percentage": 10,
    "canary_duration_minutes": 10,
    "rollback_on_error_rate": 0.01
  },
  "resources": {
    "cpu": { "request": "250m", "limit": "1000m" },
    "memory": { "request": "256Mi", "limit": "1Gi" },
    "gpu": false
  },
  "scaling": {
    "min_replicas": 1,
    "max_replicas": 5,
    "target_cpu_percent": 70
  },
  "governance": {
    "risk_class": "medium",
    "requires_approval": false,
    "pii_handling": false,
    "audit_logging": true,
    "model_risk_register_required": true
  }
}
