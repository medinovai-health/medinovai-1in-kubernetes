{
  "service": "ai-scribe",
  "version": "0.1.0",
  "repo": "medinovai/medinovai-ai-scribe",
  "type": "ml-service",
  "tier": "high",
  "description": "AI-powered clinical documentation and note generation",
  "dependencies": {
    "services": ["security", "healthLLM"],
    "databases": ["postgres-primary", "redis-cache"],
    "external": []
  },
  "health": {
    "endpoint": "/health",
    "readiness": "/ready",
    "startup_timeout_seconds": 30
  },
  "deploy": {
    "strategy": "canary",
    "canary_percentage": 10,
    "canary_duration_minutes": 10,
    "rollback_on_error_rate": 0.01
  },
  "resources": {
    "cpu": { "request": "250m", "limit": "1000m" },
    "memory": { "request": "256Mi", "limit": "1Gi" },
    "gpu": false
  },
  "scaling": {
    "min_replicas": 1,
    "max_replicas": 5,
    "target_cpu_percent": 70
  },
  "governance": {
    "risk_class": "high",
    "requires_approval": true,
    "pii_handling": false,
    "audit_logging": true,
    "clinical_approval_required": true
  }
}
