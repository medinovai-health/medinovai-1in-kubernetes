{
  "service": "saes",
  "version": "0.1.0",
  "repo": "myonsite-healthcare/saes",
  "type": "node-service",
  "tier": "high",
  "description": "Safety Adverse Event System with security, patient services, and CTMS integration",
  "dependencies": {
    "services": ["security", "patient-services", "ctms"],
    "databases": ["postgres-primary"],
    "external": ["s3", "kafka"]
  },
  "health": {
    "endpoint": "/api/health",
    "readiness": "/ready",
    "startup_timeout_seconds": 30
  },
  "deploy": {
    "strategy": "rolling",
    "canary_percentage": 10,
    "canary_duration_minutes": 10,
    "rollback_on_error_rate": 0.01
  },
  "resources": {
    "cpu": { "request": "250m", "limit": "1000m" },
    "memory": { "request": "256Mi", "limit": "1Gi" },
    "gpu": false
  },
  "scaling": {
    "min_replicas": 1,
    "max_replicas": 5,
    "target_cpu_percent": 70
  },
  "governance": {
    "risk_class": "high",
    "requires_approval": false,
    "pii_handling": true,
    "audit_logging": true
  }
}
