{
  "service": "natural-language-query",
  "version": "0.1.0",
  "repo": "medinovai/medinovai-natural-language-query",
  "type": "ml-service",
  "tier": "normal",
  "description": "Natural language to structured query translation for clinical data",
  "dependencies": {
    "services": ["security", "healthLLM", "data-services"],
    "databases": ["postgres-primary"],
    "external": []
  },
  "health": {
    "endpoint": "/health",
    "readiness": "/ready",
    "startup_timeout_seconds": 30
  },
  "deploy": {
    "strategy": "rolling",
    "canary_percentage": 10,
    "canary_duration_minutes": 10,
    "rollback_on_error_rate": 0.01
  },
  "resources": {
    "cpu": { "request": "250m", "limit": "1000m" },
    "memory": { "request": "256Mi", "limit": "1Gi" },
    "gpu": false
  },
  "scaling": {
    "min_replicas": 1,
    "max_replicas": 5,
    "target_cpu_percent": 70
  },
  "governance": {
    "risk_class": "medium",
    "requires_approval": false,
    "pii_handling": false,
    "audit_logging": true
  }
}
