{
  "service": "patient-services",
  "version": "0.1.0",
  "repo": "medinovai/medinovai-patient-onboarding",
  "type": "python-service",
  "tier": "critical",
  "description": "Patient services and onboarding core functionality",
  "dependencies": {
    "services": ["security", "data-services", "consent-preference-api"],
    "databases": ["postgres-primary", "redis-cache"],
    "external": []
  },
  "health": {
    "endpoint": "/health",
    "readiness": "/ready",
    "startup_timeout_seconds": 30
  },
  "deploy": {
    "strategy": "canary",
    "canary_percentage": 10,
    "canary_duration_minutes": 10,
    "rollback_on_error_rate": 0.01
  },
  "resources": {
    "cpu": { "request": "250m", "limit": "1000m" },
    "memory": { "request": "256Mi", "limit": "1Gi" },
    "gpu": false
  },
  "scaling": {
    "min_replicas": 1,
    "max_replicas": 5,
    "target_cpu_percent": 70
  },
  "governance": {
    "risk_class": "critical",
    "requires_approval": true,
    "pii_handling": true,
    "audit_logging": true
  }
}
