{
  "service": "wait-list-balancer",
  "version": "0.1.0",
  "repo": "medinovai/medinovai-wait-list-balancer",
  "type": "python-service",
  "tier": "normal",
  "description": "Waitlist management and load balancing across providers",
  "dependencies": {
    "services": ["security", "smart-scheduler", "patient-services"],
    "databases": ["postgres-primary", "redis-cache", "kafka"],
    "external": []
  },
  "health": {
    "endpoint": "/healthz",
    "readiness": "/ready",
    "startup_timeout_seconds": 30
  },
  "deploy": {
    "strategy": "rolling",
    "canary_percentage": 10,
    "canary_duration_minutes": 10,
    "rollback_on_error_rate": 0.01
  },
  "resources": {
    "cpu": { "request": "250m", "limit": "1000m" },
    "memory": { "request": "256Mi", "limit": "1Gi" },
    "gpu": false
  },
  "scaling": {
    "min_replicas": 1,
    "max_replicas": 5,
    "target_cpu_percent": 70
  },
  "governance": {
    "risk_class": "medium",
    "requires_approval": false,
    "pii_handling": false,
    "audit_logging": true
  }
}
