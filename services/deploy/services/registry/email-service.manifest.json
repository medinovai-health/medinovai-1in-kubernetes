{
  "service": "email-service",
  "version": "0.1.0",
  "repo": "myonsite-healthcare/email-service",
  "type": "python-service",
  "tier": "normal",
  "description": "Email service with security and Redis queue",
  "dependencies": {
    "services": ["security"],
    "databases": [],
    "external": ["redis"]
  },
  "health": {
    "endpoint": "/health",
    "readiness": "/ready",
    "startup_timeout_seconds": 30
  },
  "deploy": {
    "strategy": "rolling",
    "canary_percentage": 10,
    "canary_duration_minutes": 10,
    "rollback_on_error_rate": 0.01
  },
  "resources": {
    "cpu": { "request": "250m", "limit": "1000m" },
    "memory": { "request": "256Mi", "limit": "1Gi" },
    "gpu": false
  },
  "scaling": {
    "min_replicas": 1,
    "max_replicas": 5,
    "target_cpu_percent": 70
  },
  "governance": {
    "risk_class": "low",
    "requires_approval": false,
    "pii_handling": false,
    "audit_logging": true
  }
}
