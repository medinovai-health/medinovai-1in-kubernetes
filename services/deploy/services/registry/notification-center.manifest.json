{
  "service": "notification-center",
  "version": "0.1.0",
  "repo": "myonsite-healthcare/medinovai-notification-center",
  "type": "node-service",
  "tier": "high",
  "description": "Notification routing and delivery center",
  "dependencies": {
    "services": ["security-service"],
    "databases": ["postgres-primary", "redis-cache"],
    "external": ["rabbitmq"]
  },
  "health": {
    "endpoint": "/health",
    "readiness": "/ready",
    "startup_timeout_seconds": 30
  },
  "deploy": {
    "strategy": "rolling",
    "canary_percentage": 5,
    "canary_duration_minutes": 15,
    "rollback_on_error_rate": 0.005
  },
  "resources": {
    "cpu": { "request": "250m", "limit": "1000m" },
    "memory": { "request": "256Mi", "limit": "1Gi" },
    "gpu": false
  },
  "scaling": {
    "min_replicas": 1,
    "max_replicas": 10,
    "target_cpu_percent": 60
  },
  "governance": {
    "risk_class": "high",
    "requires_approval": true,
    "pii_handling": false,
    "audit_logging": true
  }
}
