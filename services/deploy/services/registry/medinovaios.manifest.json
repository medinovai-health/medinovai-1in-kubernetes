{
  "service": "medinovaios",
  "version": "0.1.0",
  "repo": "myonsite-healthcare/medinovaios",
  "type": "node-service",
  "tier": "critical",
  "description": "Master Menu System - unified SSO entry and BAC portal for all MedinovAI services",
  "dependencies": {
    "services": ["security", "universal-sign-on", "role-based-permissions", "api-gateway", "registry"],
    "databases": [],
    "external": []
  },
  "health": {
    "endpoint": "/health",
    "readiness": "/ready",
    "startup_timeout_seconds": 30
  },
  "deploy": {
    "strategy": "sequential",
    "canary_percentage": 10,
    "canary_duration_minutes": 10,
    "rollback_on_error_rate": 0.01
  },
  "resources": {
    "cpu": { "request": "250m", "limit": "1000m" },
    "memory": { "request": "256Mi", "limit": "1Gi" },
    "gpu": false
  },
  "scaling": {
    "min_replicas": 1,
    "max_replicas": 5,
    "target_cpu_percent": 70
  },
  "governance": {
    "risk_class": "critical",
    "requires_approval": true,
    "pii_handling": false,
    "audit_logging": true
  }
}
