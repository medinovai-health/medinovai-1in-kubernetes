# AtlasOS PRODUCTION Environment — Port range: +3000 offset
# NEVER commit this file with real secrets. Copy to /etc/atlasos/prod.env on the host.
# Usage: ./scripts/env-manager.sh start prod

COMPOSE_PROJECT_NAME=atlasos-prod
HATTS_ENVIRONMENT=production
FLASK_DEBUG=false
LOG_LEVEL=WARNING
AUTH_ENABLED=true

# ─── Database (production-grade settings) ─────────────────────────────────
DB_USER=atlasos
DB_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
ATLASOS_DB_PORT=8433
KEYCLOAK_PORT=11180
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
KEYCLOAK_REALM=medinov-ai
KEYCLOAK_AUDIENCE=medinovai-atlas
KEYCLOAK_DEV_ALLOW_HS256=false
REDIS_PORT=29379
VAULT_PORT=31200

# ─── Port Mappings (+3000 from dev) ──────────────────────────────────────
TRAEFIK_HTTP_PORT=11080
