# AtlasOS Base Environment — Shared defaults
# All environments inherit these values. Override in per-environment files.

# ─── Database ─────────────────────────────────────────────────────────────
DB_USER=atlasos
# DB_PASSWORD must be set in per-environment file

# ─── Local-First Model Routing ────────────────────────────────────────────
LLM_ENDPOINT=http://aifactory-gateway:8300
OLLAMA_HOST=http://aifactory-gateway:8300
EMBEDDED_OLLAMA_HOST=http://ollama-embedded:11434
ATLASOS_LOCAL_MODEL=qwen2.5:32b
ATLASOS_PRIMARY_MODEL=qwen2.5:32b
ATLASOS_EMBEDDED_MODEL=smollm2:360m

# ─── Service Defaults ─────────────────────────────────────────────────────
ATLAS_VERSION=2.1.0
ATLAS_GIT_SHA=dev
ATLAS_HOME=~/.atlas
ATLAS_STATE_DIR=~/.atlas

# ─── Instance Identity ──────────────────────────────────────────────────
# Each AtlasOS deployment has a unique identity. Set by install_atlasos.sh.
# Override in per-environment files for multi-instance deployments.
ATLASOS_INSTANCE_ID=ins_default
ATLASOS_INSTANCE_NAME=medinovai
ATLASOS_DISPLAY_NAME=MedinovAI
ATLASOS_DEFAULT_TENANT=medinovai
ATLASOS_ENVIRONMENT=development

# ─── Storage ──────────────────────────────────────────────────────────────
STORAGE_BACKEND=file
EVENT_STORAGE_BACKEND=postgresql
MEMORY_STORAGE_BACKEND=postgresql
GOV_STORAGE_BACKEND=postgresql
