# MedinovAI Coordinator — Environment Variables
# Copy to .env and fill in all values before starting.

# -------------------------
# REQUIRED — change all of these
# -------------------------

# One-time join token — share with team admins to onboard nodes
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
MEDINOVAI_JOIN_TOKEN=change-me-generate-a-secure-token

# Admin API token — for dashboard and task dispatch
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
MEDINOVAI_ADMIN_TOKEN=change-me-generate-a-secure-token

# HMAC signing secret for node tokens
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
MEDINOVAI_HMAC_SECRET=change-me-generate-a-secure-hex-secret

# PostgreSQL password
DB_PASSWORD=change-me-strong-db-password

# -------------------------
# Mattermost alerting
# -------------------------
# Get from: Mattermost → Settings → Integrations → Incoming Webhooks
MATTERMOST_WEBHOOK_URL=https://your-mattermost.medinovai.com/hooks/XXXXXXXXX
MATTERMOST_CHANNEL=medinovai-agents

# -------------------------
# Cloudflare Tunnel (optional, for public internet access)
# -------------------------
# Get from: https://dash.cloudflare.com → Zero Trust → Tunnels → Create
CLOUDFLARE_TUNNEL_TOKEN=

# -------------------------
# Agent versioning
# -------------------------
CURRENT_AGENT_VERSION=1.0.0
AGENT_DOWNLOAD_URL=https://agent.medinovai.com/agent/medinovai_agent.py

# -------------------------
# General
# -------------------------
ENV=production
LOG_LEVEL=INFO
