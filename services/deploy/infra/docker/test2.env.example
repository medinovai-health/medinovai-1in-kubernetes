# TEST2 Greenfield Stack — Environment Variables Template
# ─────────────────────────────────────────────────────────────────────────────
# USAGE: cp infra/docker/test2.env.example infra/docker/test2.env
#        Then fill in secrets. NEVER commit test2.env (it's in .gitignore).
#
# QUICK START: make test2-up
# FULL DOCS:   docs/TEST2-DEPLOYMENT-RUNBOOK.md
# ─────────────────────────────────────────────────────────────────────────────

# ─── Docker / Registry ───────────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=TEST2
REGISTRY=ghcr.io/myonsite-healthcare
TAG=latest

# ─── Repository Paths (used by build: directives and build-all-test2.sh) ─────
# Set to the parent directory containing all medinovai-health repos
REPOS_PATH=/Users/yourname/Github
# Full path to the medinovai-Atlas repo (used by brain/orchestrator)
ATLASOS_PATH=${REPOS_PATH}/medinovai-health/medinovai-Atlas

# ─── AWS S3 ──────────────────────────────────────────────────────────────────
AWS_REGION=us-west-1
AWS_DEFAULT_REGION=us-west-1
S3_BUCKET_NAME=your-s3-bucket-name
S3_ENDPOINT=https://s3.us-west-1.amazonaws.com
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY

# ─── AI / Ollama ─────────────────────────────────────────────────────────────
# Ollama must be running on the host machine (no Docker install needed)
OLLAMA_HOST=http://host.docker.internal:11434
AI_MODEL_PRIMARY=deepseek-r1:70b
AI_MODEL_FAST=qwen3:8b
AI_MODEL_CODER=qwen3-coder:latest
AI_MODEL_VISION=qwen3-vl:latest

# ─── Kafka Cluster Identity ───────────────────────────────────────────────────
# IMPORTANT: Set ONCE, never change. If you change this, you MUST reset both volumes:
#   make test2-kafka-reset
# Generate a new ID: docker run --rm confluentinc/cp-kafka:7.5.0 kafka-storage random-uuid
# Then base64-encode it: echo -n "YOUR-UUID" | base64
KAFKA_CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qk

# ─── Database Credentials ─────────────────────────────────────────────────────
POSTGRES_PASSWORD=TEST2_pg_pw_2026
REDIS_PASSWORD=TEST2_redis_pw_2026
MONGO_PASSWORD=TEST2_mongo_pw_2026
RABBITMQ_PASSWORD=TEST2_rmq_pw_2026

# ─── Vault ───────────────────────────────────────────────────────────────────
# DEV MODE token (local only — never use in production)
VAULT_TOKEN=TEST2-vault-dev-token-2026

# ─── Keycloak / IAM ──────────────────────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=TEST2_kc_admin_2026
SUPERADMIN_EMAIL=superadmin@medinov.ai
SUPERADMIN_PASSWORD=TEST2_superadmin_2026

# ─── Grafana ─────────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=admin

# ─── GitHub ──────────────────────────────────────────────────────────────────
GITHUB_ORG=myonsite-healthcare
GITHUB_TOKEN=YOUR_GITHUB_TOKEN

# ─── Port Assignments (16600-16999, no overlap with other stacks) ─────────────
PORT_ORCHESTRATOR_UI=16600
PORT_POSTGRES_PRIMARY=16610
PORT_POSTGRES_CLINICAL=16611
