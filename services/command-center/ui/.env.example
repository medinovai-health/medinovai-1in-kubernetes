# Copy to .env.local for development. NEVER commit .env.local to git.

# ── Required ──────────────────────────────────────────────────────────────
# GitHub API token for Brain sync and repo access
GITHUB_TOKEN=ghp_your_token_here

# OpenAI API key for Nexus fallback model (gpt-4.1-mini)
OPENAI_API_KEY=sk-your-key-here

# AtlasOS gateway URL for environment health checks
ATLASOS_GATEWAY_URL=http://atlasos-gateway:8080

# Ollama server for Nexus primary model
OLLAMA_HOST=http://ollama:11434

# GitHub webhook secret for Brain sync webhooks
GITHUB_WEBHOOK_SECRET=your-webhook-secret-here

# ── Optional ──────────────────────────────────────────────────────────────
# NextAuth secret for session management
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_URL=http://localhost:9443

# ── Public (safe to expose to browser) ───────────────────────────────────
NEXT_PUBLIC_ENVIRONMENT=dev
NEXT_PUBLIC_BUILD_ID=local
NEXT_PUBLIC_COMMAND_CENTER_VERSION=3.0.0
