{
  "service": "medical-fax-processing",
  "version": "0.1.0",
  "repo": "medinovai/medinovai-medical-fax-processing",
  "type": "ml-service",
  "tier": "high",
  "description": "Medical fax ingestion, OCR, and document processing",
  "dependencies": {
    "services": ["security", "image-to-text-ocr"],
    "databases": ["postgres-primary", "mongodb", "redis-cache"],
    "external": ["s3"]
  },
  "health": {
    "endpoint": "/health",
    "readiness": "/ready",
    "startup_timeout_seconds": 30
  },
  "deploy": {
    "strategy": "canary",
    "canary_percentage": 10,
    "canary_duration_minutes": 10,
    "rollback_on_error_rate": 0.01
  },
  "resources": {
    "cpu": { "request": "250m", "limit": "1000m" },
    "memory": { "request": "256Mi", "limit": "1Gi" },
    "gpu": false
  },
  "scaling": {
    "min_replicas": 1,
    "max_replicas": 5,
    "target_cpu_percent": 70
  },
  "governance": {
    "risk_class": "high",
    "requires_approval": true,
    "pii_handling": true,
    "audit_logging": true
  }
}
