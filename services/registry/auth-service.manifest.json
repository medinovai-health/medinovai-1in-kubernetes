{
  "service": "auth-service",
  "version": "0.1.0",
  "repo": "myonsite-healthcare/medinovai-auth-service",
  "type": "node-service",
  "tier": "critical",
  "description": "Authentication and authorization service (JWT, RBAC, SSO)",
  "dependencies": {
    "services": [],
    "databases": ["postgres-primary", "redis-cache"],
    "external": []
  },
  "health": {
    "endpoint": "/health",
    "readiness": "/ready",
    "startup_timeout_seconds": 30
  },
  "deploy": {
    "strategy": "canary",
    "canary_percentage": 5,
    "canary_duration_minutes": 15,
    "rollback_on_error_rate": 0.005
  },
  "resources": {
    "cpu": { "request": "250m", "limit": "1000m" },
    "memory": { "request": "256Mi", "limit": "1Gi" },
    "gpu": false
  },
  "scaling": {
    "min_replicas": 2,
    "max_replicas": 10,
    "target_cpu_percent": 60
  },
  "governance": {
    "risk_class": "critical",
    "requires_approval": true,
    "pii_handling": true,
    "audit_logging": true
  }
}
