{
  "service": "real-time-stream-bus",
  "version": "0.1.0",
  "repo": "myonsite-healthcare/medinovai-real-time-stream-bus",
  "type": "node-service",
  "tier": "high",
  "description": "Real-time event streaming and message bus",
  "dependencies": {
    "services": ["security-service"],
    "databases": ["redis-cache"],
    "external": ["kafka"]
  },
  "health": {
    "endpoint": "/health",
    "readiness": "/ready",
    "startup_timeout_seconds": 30
  },
  "deploy": {
    "strategy": "rolling",
    "canary_percentage": 5,
    "canary_duration_minutes": 15,
    "rollback_on_error_rate": 0.005
  },
  "resources": {
    "cpu": { "request": "500m", "limit": "2000m" },
    "memory": { "request": "512Mi", "limit": "2Gi" },
    "gpu": false
  },
  "scaling": {
    "min_replicas": 2,
    "max_replicas": 10,
    "target_cpu_percent": 60
  },
  "governance": {
    "risk_class": "high",
    "requires_approval": true,
    "pii_handling": false,
    "audit_logging": true
  }
}
