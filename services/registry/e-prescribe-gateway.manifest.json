{
  "service": "e-prescribe-gateway",
  "version": "0.1.0",
  "repo": "myonsite-healthcare/e-prescribe-gateway",
  "type": "python-service",
  "tier": "high",
  "description": "E-prescribe gateway for security, patient services, and drug interaction checking",
  "dependencies": {
    "services": ["security", "patient-services", "drug-interaction-checker"],
    "databases": [],
    "external": []
  },
  "health": {
    "endpoint": "/health",
    "readiness": "/ready",
    "startup_timeout_seconds": 30
  },
  "deploy": {
    "strategy": "rolling",
    "canary_percentage": 10,
    "canary_duration_minutes": 10,
    "rollback_on_error_rate": 0.01
  },
  "resources": {
    "cpu": { "request": "250m", "limit": "1000m" },
    "memory": { "request": "256Mi", "limit": "1Gi" },
    "gpu": false
  },
  "scaling": {
    "min_replicas": 1,
    "max_replicas": 5,
    "target_cpu_percent": 70
  },
  "governance": {
    "risk_class": "high",
    "requires_approval": true,
    "pii_handling": false,
    "audit_logging": true
  }
}
