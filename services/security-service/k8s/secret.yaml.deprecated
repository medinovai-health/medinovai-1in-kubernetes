apiVersion: v1
kind: Secret
metadata:
  name: medinovai-security-service-secrets
  namespace: medinovai-services
  labels:
    app: medinovai-security-service
type: Opaque
stringData:
  # Keycloak admin password - CHANGE IN PRODUCTION
  KEYCLOAK_ADMIN_PASSWORD: "admin123"

  # Database credentials - should match postgres secret
  POSTGRES_PASSWORD: "postgres123"
  REDIS_PASSWORD: "redis123"
