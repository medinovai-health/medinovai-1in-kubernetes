{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "agent_provisioned",
  "description": "Emitted when an agent is provisioned",
  "type": "object",
  "required": ["event_type", "timestamp", "source", "tenant_id"],
  "properties": {
    "event_type": { "const": "agent_provisioned" },
    "timestamp": { "type": "string", "format": "date-time" },
    "source": { "type": "string" },
    "tenant_id": { "type": "string" },
    "correlation_id": { "type": "string" },
    "payload": {
      "type": "object",
      "properties": {
        "agent_id": { "type": "string" },
        "agent_type": { "type": "string" },
        "repo": { "type": "string" },
        "environment": { "type": "string" },
        "provisioned_by": { "type": "string" }
      }
    }
  },
  "additionalProperties": true
}
