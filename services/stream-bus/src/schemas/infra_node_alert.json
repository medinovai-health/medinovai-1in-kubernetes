{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "infra_node_alert",
  "description": "Emitted when infrastructure node alert is raised",
  "type": "object",
  "required": ["event_type", "timestamp", "source", "tenant_id"],
  "properties": {
    "event_type": { "const": "infra_node_alert" },
    "timestamp": { "type": "string", "format": "date-time" },
    "source": { "type": "string" },
    "tenant_id": { "type": "string" },
    "correlation_id": { "type": "string" },
    "payload": {
      "type": "object",
      "properties": {
        "node_name": { "type": "string" },
        "alert_type": { "type": "string" },
        "severity": { "type": "string", "enum": ["critical", "warning", "info"] },
        "message": { "type": "string" },
        "metric": { "type": "string" },
        "value": { "type": "number" }
      }
    }
  },
  "additionalProperties": true
}
