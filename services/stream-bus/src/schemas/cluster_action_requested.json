{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "cluster_action_requested",
  "description": "Emitted when a cluster action is requested",
  "type": "object",
  "required": ["event_type", "timestamp", "source", "tenant_id"],
  "properties": {
    "event_type": { "const": "cluster_action_requested" },
    "timestamp": { "type": "string", "format": "date-time" },
    "source": { "type": "string" },
    "tenant_id": { "type": "string" },
    "correlation_id": { "type": "string" },
    "payload": {
      "type": "object",
      "properties": {
        "action": { "type": "string" },
        "cluster_name": { "type": "string" },
        "requested_by": { "type": "string" },
        "parameters": { "type": "object" },
        "requires_approval": { "type": "boolean" }
      }
    }
  },
  "additionalProperties": true
}
