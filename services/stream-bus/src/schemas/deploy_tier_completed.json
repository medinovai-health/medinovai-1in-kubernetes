{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "deploy_tier_completed",
  "description": "Emitted when a deployment tier completes",
  "type": "object",
  "required": ["event_type", "timestamp", "source", "tenant_id"],
  "properties": {
    "event_type": { "const": "deploy_tier_completed" },
    "timestamp": { "type": "string", "format": "date-time" },
    "source": { "type": "string" },
    "tenant_id": { "type": "string" },
    "correlation_id": { "type": "string" },
    "payload": {
      "type": "object",
      "properties": {
        "tier": { "type": "integer" },
        "tier_name": { "type": "string" },
        "status": { "type": "string", "enum": ["success", "failure", "partial"] },
        "duration_seconds": { "type": "number" },
        "services_deployed": { "type": "array", "items": { "type": "string" } },
        "environment": { "type": "string" }
      }
    }
  },
  "additionalProperties": true
}
