# .editorconfig — medinovai-canary-rollout-orchestrator
# MedinovAI Coding Standards v3.0.0 | medinovai-ai-standards/CODING_STANDARDS.md
# https://editorconfig.org

root = true

[*]
charset               = utf-8
end_of_line           = lf
insert_final_newline  = true
trim_trailing_whitespace = true
indent_style          = space
indent_size           = 4

[*.{json,yaml,yml}]
indent_size = 2

[*.{ts,tsx,js,jsx}]
indent_size = 2

[*.{cs,csproj,sln}]
indent_size = 4

[*.{swift,kt,kts}]
indent_size = 4

[Makefile]
indent_style = tab

[*.md]
trim_trailing_whitespace = false
