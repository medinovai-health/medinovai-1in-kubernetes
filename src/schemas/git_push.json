{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "git_push",
  "description": "Emitted when a Git push occurs",
  "type": "object",
  "required": ["event_type", "timestamp", "source", "tenant_id"],
  "properties": {
    "event_type": { "const": "git_push" },
    "timestamp": { "type": "string", "format": "date-time" },
    "source": { "type": "string" },
    "tenant_id": { "type": "string" },
    "correlation_id": { "type": "string" },
    "payload": {
      "type": "object",
      "properties": {
        "repo": { "type": "string" },
        "branch": { "type": "string" },
        "commit_sha": { "type": "string" },
        "pusher": { "type": "string" },
        "ref": { "type": "string" },
        "commits_count": { "type": "integer" }
      }
    }
  },
  "additionalProperties": true
}
