extends: default

rules:
  # Allow longer lines for YAML files
  line-length:
    max: 120
    level: warning
  
  # Allow comments
  comments:
    min-spaces-from-content: 1
  
  # Allow document start
  document-start:
    present: false
  
  # Allow trailing spaces in some contexts
  trailing-spaces:
    level: warning
  
  # Allow multiple documents
  document-end:
    present: false
  
  # Allow flow style for short mappings
  braces:
    min-spaces-inside: 0
    max-spaces-inside: 1
  
  brackets:
    min-spaces-inside: 0
    max-spaces-inside: 1
  
  # Allow truthy values
  truthy:
    allowed-values: ['true', 'false', 'yes', 'no', 'on', 'off']
  
  # Allow octal values
  octal-values:
    forbid-implicit-octal: false
  
  # Allow key ordering
  key-ordering: disable
  
  # Allow duplicate keys (sometimes needed for Kubernetes)
  key-duplicates: disable
  
  # Allow anchors and aliases
  anchors:
    max-length: 128
  
  # Allow indentation
  indentation:
    spaces: 2
    indent-sequences: true
    check-multi-line-strings: false








