# MedinovAI Docker — Environment Overrides
# Copy to infra/docker/.env and customize. NEVER commit .env.
#
# ─── Self-Contained Bootstrap ─────────────────────────────────────────────────
# The `deployer` service installs Atlas and writes all config/workspace files
# into named Docker volumes (atlas-config, atlas-workspaces, atlas-ui-source).
# No host-side ~/.atlas/ setup is required — `docker compose up` handles it.
#
# ATLAS_HOME is set automatically to /atlas-home inside the deployer container.
# Uncomment only if you need to override the volume mount target:
# ATLAS_HOME=/atlas-home
#
# Atlas UI WebSocket target — defaults to the sibling atlas-agent container.
# Override to connect to a host-side agent instead:
# NEXT_PUBLIC_AGENT_URL=ws://host.docker.internal:8765
#
# ─── Infrastructure ───────────────────────────────────────────────────────────
# POSTGRES_PASSWORD=localdev
# REDIS_PASSWORD=localdev
# GRAFANA_ADMIN_PASSWORD=admin

# ─── Vault (HashiCorp Vault — dev mode) ───────────────────────────────────────
# Dev mode root token — used only in local Docker Compose development.
# Production uses Vault with Raft storage and K8s auth (no static root token).
# VAULT_DEV_ROOT_TOKEN=medinovai-dev-token

# ─── AppRole credentials (written automatically by init-vault.sh) ─────────────
# Do not set these manually. init-vault.sh generates and appends them below.
# MEDINOVAIOS_VAULT_ROLE_ID=<auto>
# MEDINOVAIOS_VAULT_SECRET_ID=<auto>
# API_GATEWAY_VAULT_ROLE_ID=<auto>
# API_GATEWAY_VAULT_SECRET_ID=<auto>
# AUTH_SERVICE_VAULT_ROLE_ID=<auto>
# AUTH_SERVICE_VAULT_SECRET_ID=<auto>
# NOTIFICATION_SERVICE_VAULT_ROLE_ID=<auto>
# NOTIFICATION_SERVICE_VAULT_SECRET_ID=<auto>

# ─── medinovai-registry Vault connection ─────────────────────────────────────
# The registry service expects VAULT_ADDR to fetch its own secrets (MinIO, DB, OIDC).
# When running registry alongside this stack: VAULT_ADDR=http://medinovai-vault:8200
# REGISTRY_VAULT_ROLE_ID=<generated by init-vault.sh>
# REGISTRY_VAULT_SECRET_ID=<generated by init-vault.sh>

# ─── Atlas Agent Gateway ──────────────────────────────────────────────────────
# Slack (required for Slack channel listening)
SLACK_APP_TOKEN=xapp-REPLACE_ME
SLACK_BOT_TOKEN=xoxb-REPLACE_ME

# LLM Provider (at least one required; Ollama is the local fallback)
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
# OPENAI_API_KEY=sk-REPLACE_ME

# Webhooks
HOOKS_TOKEN=REPLACE_WITH_RANDOM_SECRET

# Ollama local model (default: qwen2.5:1.5b — pulled automatically)
OLLAMA_DEFAULT_MODEL=qwen2.5:1.5b

# ─── IAM / Single Sign-On (Keycloak) ──────────────────────────────────────────
# Path to the cloned MedinovAI-security-service repo (sibling directory).
# Set automatically by bootstrap-all.sh. Override if repo is in a different location.
# SECURITY_SERVICE_PATH=../../../MedinovAI-security-service

# Keycloak master admin (internal Keycloak admin console — NOT your app login).
# Login at: http://localhost:8081/admin
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=localdev        # CHANGE IN PRODUCTION

# SuperAdmin for medinovaiOS portal — THIS IS YOUR ONE LOGIN
# Login at: http://localhost:3030
SUPERADMIN_EMAIL=superadmin@medinov.ai
SUPERADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# medinovaiOS OIDC client secret (generated by Keycloak for the confidential client).
# Run `make security-seed` after first bootstrap to populate this, then set it here.
# KEYCLOAK_CLIENT_SECRET=

# Browser-facing Keycloak URL (OIDC redirects go here).
# Docker dev default is http://localhost:8081 (set in docker-compose.dev.yml).
# KEYCLOAK_PUBLIC_URL=http://localhost:8081
# Production: KEYCLOAK_PUBLIC_URL=https://auth.medinov.ai
# MEDINOVAIOS_PUBLIC_URL=https://portal.medinov.ai

# Keycloak ownership policy for deploy scripts:
# - KEYCLOAK_MODE=platform   => medinovai-Deploy tier0 owns Keycloak (default)
# - KEYCLOAK_MODE=standalone => external security-service stack owns Keycloak
# Ownership gate rollout mode:
# - KEYCLOAK_OWNERSHIP_MODE=warn (default)
# - KEYCLOAK_OWNERSHIP_MODE=enforce
# KEYCLOAK_MODE=platform
# KEYCLOAK_OWNERSHIP_MODE=warn

# Twilio SMS OTP (optional — for MFA)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# Optional integrations
# CRM_API_KEY=REPLACE_ME
# TICKETS_API_KEY=REPLACE_ME
# GMAIL_SERVICE_ACCOUNT_JSON=/path/to/service-account.json
# ACCOUNTING_API_KEY=REPLACE_ME
# PAGERDUTY_API_KEY=REPLACE_ME
# LINEAR_API_KEY=REPLACE_ME
