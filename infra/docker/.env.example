# MedinovAI Docker — Environment Overrides
# Copy to infra/docker/.env and customize. NEVER commit .env.
#
# ─── Self-Contained Bootstrap ─────────────────────────────────────────────────
# The `deployer` service installs Atlas and writes all config/workspace files
# into named Docker volumes (atlas-config, atlas-workspaces, atlas-ui-source).
# No host-side ~/.atlas/ setup is required — `docker compose up` handles it.
#
# ATLAS_HOME is set automatically to /atlas-home inside the deployer container.
# Uncomment only if you need to override the volume mount target:
# ATLAS_HOME=/atlas-home
#
# Atlas UI WebSocket target — defaults to the sibling atlas-agent container.
# Override to connect to a host-side agent instead:
# NEXT_PUBLIC_AGENT_URL=ws://host.docker.internal:8765
#
# ─── Infrastructure ───────────────────────────────────────────────────────────
# POSTGRES_PASSWORD=localdev
# REDIS_PASSWORD=localdev
# GRAFANA_ADMIN_PASSWORD=admin

# ─── Atlas Agent Gateway ──────────────────────────────────────────────────────
# Slack (required for Slack channel listening)
SLACK_APP_TOKEN=xapp-REPLACE_ME
SLACK_BOT_TOKEN=xoxb-REPLACE_ME

# LLM Provider (at least one required; Ollama is the local fallback)
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
# OPENAI_API_KEY=sk-REPLACE_ME

# Webhooks
HOOKS_TOKEN=REPLACE_WITH_RANDOM_SECRET

# Ollama local model (default: qwen2.5:1.5b — pulled automatically)
OLLAMA_DEFAULT_MODEL=qwen2.5:1.5b

# Optional integrations
# CRM_API_KEY=REPLACE_ME
# TICKETS_API_KEY=REPLACE_ME
# GMAIL_SERVICE_ACCOUNT_JSON=/path/to/service-account.json
# ACCOUNTING_API_KEY=REPLACE_ME
# PAGERDUTY_API_KEY=REPLACE_ME
# LINEAR_API_KEY=REPLACE_ME
