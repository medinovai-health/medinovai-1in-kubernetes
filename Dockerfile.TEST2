FROM python:3.12-slim
WORKDIR /app
RUN apt-get update && apt-get install -y --no-install-recommends curl && rm -rf /var/lib/apt/lists/*
COPY requirements.txt* ./
RUN pip install --no-cache-dir -r requirements.txt 2>/dev/null || pip install --no-cache-dir fastapi uvicorn[standard] pydantic prometheus-client structlog
RUN pip install --no-cache-dir fastapi uvicorn[standard] pydantic prometheus-client structlog 2>/dev/null || true
COPY . .
EXPOSE 8080
HEALTHCHECK --interval=15s --timeout=5s --start-period=20s --retries=5 \
  CMD curl -sf http://localhost:8080/health || exit 1
ENV SERVICE_NAME=medinovai-canary-rollout-orchestrator
CMD ["uvicorn", "main_test2:app", "--host", "0.0.0.0", "--port", "8080"]
