FROM ghcr.io/myonsite-healthcare/medinovai-python-base:3.12
# Base image includes: fastapi, uvicorn, pydantic, requests, httpx, prometheus-client
WORKDIR /app
# curl already available in base image
RUN pip install --no-cache-dir fastapi "uvicorn[standard]" pydantic kafka-python redis aiohttp pyyaml
COPY main_test2.py .
ENV SERVICE_NAME=medinovai-real-time-stream-bus PORT=3000
EXPOSE 3000
HEALTHCHECK --interval=15s --timeout=5s --start-period=20s --retries=3 \
  CMD curl -sf http://localhost:3000/health || exit 1
CMD ["python3", "main_test2.py"]
