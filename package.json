{
  "name": "medinovai-infrastructure-validation",
  "version": "2.0.0",
  "description": "MedinovAI Infrastructure Validation with Agent Swarms and Playwright Tests",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:report": "playwright show-report",
    "test:install": "playwright install",
    "test:install-deps": "playwright install-deps",
    "dev": "echo 'Development server would start here'",
    "validate": "./scripts/validation_orchestrator.sh",
    "validate:swarms": "./scripts/create_validation_swarms.sh && ./scripts/execute_validation_swarms.sh",
    "validate:monitor": "./scripts/monitor_validation_swarms.sh monitor",
    "validate:report": "./scripts/monitor_validation_swarms.sh summary"
  },
  "keywords": [
    "medinovai",
    "infrastructure",
    "validation",
    "playwright",
    "testing",
    "agent-swarms",
    "automation"
  ],
  "author": "MedinovAI Platform Team",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.40.0"
  },
  "dependencies": {
    "jq": "^1.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/myonsite-healthcare/medinovai-infrastructure.git"
  },
  "bugs": {
    "url": "https://github.com/myonsite-healthcare/medinovai-infrastructure/issues"
  },
  "homepage": "https://github.com/myonsite-healthcare/medinovai-infrastructure#readme"
}








