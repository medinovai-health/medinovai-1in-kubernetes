# Temporal Cloud Environment Variables
# Copy to .env.temporal and fill in values for your environment.
# NEVER commit .env.temporal — it contains secrets.
# This file (.env.temporal.example) is safe to commit.

# ─── Temporal Cloud (Production / Staging) ───────────────────────────────────
# Your Temporal Cloud namespace (format: <namespace>.<accountId>)
TEMPORAL_NAMESPACE=medinovai-prod.abc123

# Temporal Cloud gRPC endpoint
TEMPORAL_HOST_URL=medinovai-prod.abc123.tmprl.cloud:7233

# mTLS client certificate (download from Temporal Cloud console)
TEMPORAL_TLS_CERT=/etc/temporal/certs/client.pem
TEMPORAL_TLS_KEY=/etc/temporal/certs/client.key

# ─── Target Environment ───────────────────────────────────────────────────────
# local | staging | production
TEMPORAL_ENVIRONMENT=local

# ─── Worker Identity ─────────────────────────────────────────────────────────
TEMPORAL_WORKER_BUILD_ID=medinovai-worker-1.0.0
